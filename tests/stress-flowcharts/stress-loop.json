{
  "id": "stress-loop",
  "name": "stress-loop",
  "flowchart": {
    "blocks": {
      "start": {"id": "start", "type": "start", "name": "START", "position": {"x": 0, "y": 0}},
      "init_i": {"id": "init_i", "type": "variable", "name": "INIT_I", "position": {"x": 0, "y": 100},
        "variable_name": "i", "variable_value": "0", "variable_type": "number"},
      "init_sum": {"id": "init_sum", "type": "variable", "name": "INIT_SUM", "position": {"x": 0, "y": 200},
        "variable_name": "sum", "variable_value": "0", "variable_type": "number"},
      "loop_check": {"id": "loop_check", "type": "branch", "name": "LOOP_CHECK", "position": {"x": 0, "y": 300},
        "condition": "i < 3"},
      "prompt_add": {"id": "prompt_add", "type": "prompt", "name": "ADD", "position": {"x": 0, "y": 400},
        "prompt": "What is {{sum}} + {{i}}? Reply with ONLY the number, nothing else.", "output_variable": "add_result"},
      "update_sum": {"id": "update_sum", "type": "bash", "name": "UPDATE_SUM", "position": {"x": 0, "y": 500},
        "command": "python3 -c \"print(int({{sum}}) + int({{i}}))\"", "capture_output": true, "output_variable": "sum", "output_type": "number"},
      "increment": {"id": "increment", "type": "bash", "name": "INCREMENT", "position": {"x": 0, "y": 600},
        "command": "echo $(({{i}} + 1))", "capture_output": true, "output_variable": "i", "output_type": "number"},
      "verify": {"id": "verify", "type": "branch", "name": "VERIFY", "position": {"x": 0, "y": 700},
        "condition": "sum == 3"},
      "pass": {"id": "pass", "type": "variable", "name": "PASS", "position": {"x": 0, "y": 800},
        "variable_name": "result", "variable_value": "LOOP_PASS", "variable_type": "string"},
      "fail": {"id": "fail", "type": "variable", "name": "FAIL", "position": {"x": 200, "y": 800},
        "variable_name": "result", "variable_value": "LOOP_FAIL", "variable_type": "string"},
      "end": {"id": "end", "type": "end", "name": "END", "position": {"x": 0, "y": 900}}
    },
    "connections": [
      {"id": "c1", "source_block_id": "start", "target_block_id": "init_i", "is_true_path": true},
      {"id": "c2", "source_block_id": "init_i", "target_block_id": "init_sum", "is_true_path": true},
      {"id": "c3", "source_block_id": "init_sum", "target_block_id": "loop_check", "is_true_path": true},
      {"id": "c4", "source_block_id": "loop_check", "target_block_id": "prompt_add", "is_true_path": true},
      {"id": "c5", "source_block_id": "loop_check", "target_block_id": "verify", "is_true_path": false},
      {"id": "c6", "source_block_id": "prompt_add", "target_block_id": "update_sum", "is_true_path": true},
      {"id": "c7", "source_block_id": "update_sum", "target_block_id": "increment", "is_true_path": true},
      {"id": "c8", "source_block_id": "increment", "target_block_id": "loop_check", "is_true_path": true},
      {"id": "c9", "source_block_id": "verify", "target_block_id": "pass", "is_true_path": true},
      {"id": "c10", "source_block_id": "verify", "target_block_id": "fail", "is_true_path": false},
      {"id": "c11", "source_block_id": "pass", "target_block_id": "end", "is_true_path": true},
      {"id": "c12", "source_block_id": "fail", "target_block_id": "end", "is_true_path": true}
    ],
    "start_block_id": "start"
  },
  "arguments": []
}
