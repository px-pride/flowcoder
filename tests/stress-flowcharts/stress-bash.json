{
  "id": "stress-bash",
  "name": "stress-bash",
  "flowchart": {
    "blocks": {
      "start": {"id": "start", "type": "start", "name": "START", "position": {"x": 0, "y": 0}},
      "run_echo": {"id": "run_echo", "type": "bash", "name": "ECHO", "position": {"x": 0, "y": 100},
        "command": "echo hello-from-bash", "capture_output": true, "output_variable": "echo_out", "output_type": "string"},
      "run_math": {"id": "run_math", "type": "bash", "name": "MATH", "position": {"x": 0, "y": 200},
        "command": "echo $((6 * 7))", "capture_output": true, "output_variable": "math_out", "output_type": "number"},
      "check_echo": {"id": "check_echo", "type": "branch", "name": "CHECK_ECHO", "position": {"x": 0, "y": 300},
        "condition": "echo_out == \"hello-from-bash\""},
      "check_math": {"id": "check_math", "type": "branch", "name": "CHECK_MATH", "position": {"x": 0, "y": 400},
        "condition": "math_out == 42"},
      "run_exitcode": {"id": "run_exitcode", "type": "bash", "name": "EXITCODE", "position": {"x": 0, "y": 500},
        "command": "exit 3", "continue_on_error": true, "exit_code_variable": "bash_rc"},
      "check_rc": {"id": "check_rc", "type": "branch", "name": "CHECK_RC", "position": {"x": 0, "y": 600},
        "condition": "bash_rc == 3"},
      "pass": {"id": "pass", "type": "variable", "name": "PASS", "position": {"x": 0, "y": 700},
        "variable_name": "result", "variable_value": "ALL_BASH_PASS", "variable_type": "string"},
      "fail_echo": {"id": "fail_echo", "type": "variable", "name": "FAIL_ECHO", "position": {"x": 200, "y": 350},
        "variable_name": "result", "variable_value": "FAIL_ECHO", "variable_type": "string"},
      "fail_math": {"id": "fail_math", "type": "variable", "name": "FAIL_MATH", "position": {"x": 200, "y": 450},
        "variable_name": "result", "variable_value": "FAIL_MATH", "variable_type": "string"},
      "fail_rc": {"id": "fail_rc", "type": "variable", "name": "FAIL_RC", "position": {"x": 200, "y": 650},
        "variable_name": "result", "variable_value": "FAIL_RC", "variable_type": "string"},
      "end": {"id": "end", "type": "end", "name": "END", "position": {"x": 0, "y": 800}}
    },
    "connections": [
      {"id": "c1", "source_block_id": "start", "target_block_id": "run_echo", "is_true_path": true},
      {"id": "c2", "source_block_id": "run_echo", "target_block_id": "run_math", "is_true_path": true},
      {"id": "c3", "source_block_id": "run_math", "target_block_id": "check_echo", "is_true_path": true},
      {"id": "c4", "source_block_id": "check_echo", "target_block_id": "check_math", "is_true_path": true},
      {"id": "c5", "source_block_id": "check_echo", "target_block_id": "fail_echo", "is_true_path": false},
      {"id": "c6", "source_block_id": "check_math", "target_block_id": "run_exitcode", "is_true_path": true},
      {"id": "c7", "source_block_id": "check_math", "target_block_id": "fail_math", "is_true_path": false},
      {"id": "c8", "source_block_id": "run_exitcode", "target_block_id": "check_rc", "is_true_path": true},
      {"id": "c9", "source_block_id": "check_rc", "target_block_id": "pass", "is_true_path": true},
      {"id": "c10", "source_block_id": "check_rc", "target_block_id": "fail_rc", "is_true_path": false},
      {"id": "c11", "source_block_id": "pass", "target_block_id": "end", "is_true_path": true},
